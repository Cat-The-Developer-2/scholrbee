---
type IconComponent = any;

interface Props {
  title: string;
  description: string;
  badge?: string;
  icon?: IconComponent;
  iconWrapClass?: string;
  iconClass?: string;
  cardClass?: string;
  badgeClass?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  description,
  badge,
  icon: Icon,
  iconWrapClass = "bg-white/80 text-slate-700",
  iconClass = "h-5 w-5",
  cardClass = "",
  badgeClass = "bg-indigo-100 text-indigo-700",
  titleClass = "text-slate-900",
  descriptionClass = "text-slate-600",
} = Astro.props;
---

<article
  class={`group relative overflow-hidden rounded-[28px] border border-slate-200/70 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg ${cardClass}`}
>
  <div class="flex items-start justify-between gap-4">
    <div
      class={`flex h-11 w-11 items-center justify-center rounded-2xl ${iconWrapClass}`}
    >
      {Icon ? <Icon class={iconClass} /> : null}
    </div>

    {
      badge ? (
        <span
          class={`rounded-full px-3 py-1 text-xs font-medium tracking-wide ${badgeClass}`}
        >
          {badge}
        </span>
      ) : null
    }
  </div>

  <div class="mt-8">
    <h3 class={`text-2xl font-semibold tracking-tight ${titleClass}`}>
      {title}
    </h3>
    <p class={`mt-3 max-w-md text-sm leading-6 ${descriptionClass}`}>
      {description}
    </p>
  </div>

  <div class="mt-6">
    <slot name="media" />
  </div>

  <div class="mt-5">
    <slot name="extra" />
  </div>
</article>
