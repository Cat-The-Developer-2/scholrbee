---
interface Props {
  title: string;
  subtitle?: string;
  priceValue: string;
  priceMeta?: string;
  features: string[];
  ctaLabel: string;
  ctaHref?: string;
  badge?: string;
  featured?: boolean;
  className?: string;
}

const {
  title,
  subtitle = "",
  priceValue,
  priceMeta = "",
  features = [],
  ctaLabel,
  ctaHref = "#",
  badge,
  featured = false,
  className = "",
} = Astro.props as Props;
---

<article
  class:list={[
    "relative flex h-full flex-col rounded-[16px] border shadow-[0_20px_40px_rgba(1,45,29,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_24px_50px_rgba(1,45,29,0.08)]",
    featured
      ? "border-[#012d1d]/20 bg-[#012d1d] text-white shadow-[0_28px_60px_rgba(1,45,29,0.18)]"
      : "border-[#212529]/8 bg-white text-[#012d1d]",
    className,
  ]}
>
  {
    badge ? (
      <div class="absolute left-1/2 top-0 z-10 -translate-x-1/2 -translate-y-1/2">
        <span
          class:list={[
            "inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold tracking-[0.08em] uppercase",
            featured
              ? "bg-[#ffdea9] text-[#271900]"
              : "bg-[#e0e0ff] text-[#2d328b]",
          ]}
        >
          {badge}
        </span>
      </div>
    ) : null
  }

  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <div class="space-y-2">
      <h3
        class:list={[
          "text-[20px] leading-6",
          featured ? "text-white" : "text-[#012d1d]",
        ]}
      >
        {title}
      </h3>

      {
        subtitle ? (
          <p
            class:list={[
              "text-sm leading-6",
              featured ? "text-white/72" : "text-[#414844]",
            ]}
          >
            {subtitle}
          </p>
        ) : null
      }
    </div>

    <div class="mt-5 flex items-end gap-1 border-b border-current/10 pb-5">
      <span
        class:list={[
          "text-[44px] font-semibold leading-none tracking-[-0.04em]",
          featured ? "text-white" : "text-[#012d1d]",
        ]}
      >
        {priceValue}
      </span>
      {
        priceMeta ? (
          <span
            class:list={[
              "pb-1 text-sm",
              featured ? "text-white/68" : "text-[#414844]",
            ]}
          >
            {priceMeta}
          </span>
        ) : null
      }
    </div>

    <div class="mt-5">
      <slot name="visual" />
    </div>

    <ul class="mt-5 space-y-4">
      {
        features.map((item) => (
          <li
            class:list={[
              "flex items-start gap-3 text-sm leading-6",
              featured ? "text-white/88" : "text-[#414844]",
            ]}
          >
            <span
              class:list={[
                "mt-1 inline-flex h-4 w-4 items-center justify-center rounded-[4px] border",
                featured
                  ? "border-white/25 bg-white/10"
                  : "border-[#012d1d]/15 bg-[#f1f4f9]",
              ]}
              aria-hidden="true"
            >
              <svg
                viewBox="0 0 16 16"
                class:list={[
                  "h-2.5 w-2.5",
                  featured ? "text-white" : "text-[#012d1d]",
                ]}
                fill="none"
              >
                <path
                  d="M13.5 4.75L6.375 11.875L2.5 8"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>

    <div class="mt-auto pt-6">
      <a
        href={ctaHref}
        class:list={[
          "inline-flex w-full items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition-colors duration-300",
          featured
            ? "bg-[#c1ecd4] text-[#012d1d] hover:bg-[#a5d0b9]"
            : "bg-[#ebeef3] text-[#012d1d] hover:bg-[#e0e3e8]",
        ]}
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</article>
