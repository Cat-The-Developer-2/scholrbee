---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { MoveRight } from "@lucide/astro";
---

<Layout
  title="Page Not Found - ScholrBee"
  description="The page you're looking for doesn't exist. Return to ScholrBee and continue your learning journey."
>
  <Header />

  <section
    class="px-4 sm:px-6 md:px-20 lg:px-50 min-h-screen flex flex-col items-center justify-center"
  >
    <div class="flex flex-col items-center text-center max-w-2xl">
      <!-- Error Code -->
      <div class="mb-8">
        <h1 class="text-9xl font-bold text-primary mb-4">404</h1>
        <div class="h-1 w-24 bg-primary mx-auto"></div>
      </div>

      <!-- Error Message -->
      <h2 class="text-headline-lg text-on-surface mb-4">Page Not Found</h2>

      <p class="text-body-lg text-on-surface-variant mb-8 max-w-lg">
        Oops! It looks like you've wandered off the path. The page you're
        looking for doesn't exist or has been moved. Don't worry, let's get you
        back on track!
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-primary text-on-primary rounded-lg font-medium hover:bg-primary/90 transition-colors duration-200 flex items-center justify-center gap-2"
        >
          <span>Return Home</span>
          <MoveRight size={20} />
        </a>

        <a
          href="/about"
          class="px-6 py-3 border-2 border-primary text-primary rounded-lg font-medium hover:bg-primary/10 transition-colors duration-200"
        >
          Learn More About Us
        </a>
      </div>

      <!-- Suggested Links -->
      <div class="mt-12 pt-8 border-t border-outline w-full">
        <p class="text-label-lg text-on-surface-variant mb-4">
          Here are some helpful links:
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          <a
            href="/"
            class="text-primary hover:text-primary/80 transition-colors"
          >
            Home
          </a>
          <a
            href="/about"
            class="text-primary hover:text-primary/80 transition-colors"
          >
            About
          </a>
          <a
            href="/contact"
            class="text-primary hover:text-primary/80 transition-colors"
          >
            Contact
          </a>
          <a
            href="/privacy"
            class="text-primary hover:text-primary/80 transition-colors"
          >
            Privacy Policy
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
