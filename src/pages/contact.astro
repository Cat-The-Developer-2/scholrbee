---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { Mail, Clock, MapPin, MessageSquare, Send } from "@lucide/astro";

const contactLinks = [
  { label: "General & Support Email", value: "hello@studyos.com" },
  { label: "Expected Response Time", value: "Usually within 24 hours" },
  { label: "Office & Support Hours", value: "Mon–Sat, 10:00 AM – 7:00 PM" },
];
---

<Layout
  title="Contact ScholrBee Support - Best Study App for Students"
  description="Contact ScholrBee support team for questions about our AI study app, flashcards, mind maps, study planner, or any features of our best studying app for students."
  keywords="ScholrBee contact, study app support, student study app help, studying app features, study assistant"
>
  <!-- Navbar -->
  <Header />

  <div class="px-4 sm:px-6 md:px-20 lg:px-50 flex flex-col min-h-screen">
    <!-- Intro Header -->
    <section class="py-12 sm:py-16 text-center">
      <span
        class="text-label-md text-secondary uppercase tracking-[0.12em] mb-3"
        >Connect With Us</span
      >
      <h1 class="text-headline-xl text-primary max-w-2xl mx-auto leading-tight">
        Get Help With Your Study App Experience | ScholrBee Support
      </h1>
      <p
        class="mt-4 text-body-md text-on-surface-variant max-w-xl mx-auto leading-relaxed"
      >
        Questions about our best studying app features, need help with
        flashcards or mind maps, or want to discuss study planner capabilities?
        Contact our team and we'll help you maximize your study potential.
      </p>
    </section>

    <!-- Content Grid -->
    <section class="pb-20 grid gap-10 lg:grid-cols-[1.25fr_0.75fr]">
      <!-- Contact Form Container -->
      <div
        class="rounded-3xl border border-outline-variant/40 bg-surface-container-lowest p-6 sm:p-10 shadow-subtle"
      >
        <h2 class="font-display text-headline-md text-primary mb-6">
          Send us a Message
        </h2>
        <form class="space-y-6">
          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <label for="name" class="text-sm font-semibold text-primary">
                Full Name
              </label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Arthur Pendragon"
                class="w-full rounded-xl border border-outline-variant/50 bg-surface px-4 py-3.5 text-body-md text-on-surface outline-none transition duration-300 placeholder:text-outline focus:border-primary/40 focus:ring-2 focus:ring-primary/20"
                required
              />
            </div>

            <div class="space-y-2">
              <label for="email" class="text-sm font-semibold text-primary">
                Email Address
              </label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="arthur@camelot.edu"
                class="w-full rounded-xl border border-outline-variant/50 bg-surface px-4 py-3.5 text-body-md text-on-surface outline-none transition duration-300 placeholder:text-outline focus:border-primary/40 focus:ring-2 focus:ring-primary/20"
                required
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="subject" class="text-sm font-semibold text-primary">
              Subject
            </label>
            <input
              id="subject"
              name="subject"
              type="text"
              placeholder="How can we help your studies?"
              class="w-full rounded-xl border border-outline-variant/50 bg-surface px-4 py-3.5 text-body-md text-on-surface outline-none transition duration-300 placeholder:text-outline focus:border-primary/40 focus:ring-2 focus:ring-primary/20"
              required
            />
          </div>

          <div class="space-y-2">
            <label for="message" class="text-sm font-semibold text-primary">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              placeholder="Detail your inquiry, request, or feedback here..."
              class="w-full resize-none rounded-xl border border-outline-variant/50 bg-surface px-4 py-3.5 text-body-md leading-relaxed text-on-surface outline-none transition duration-300 placeholder:text-outline focus:border-primary/40 focus:ring-2 focus:ring-primary/20"
              required></textarea>
          </div>

          <div
            class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between pt-2"
          >
            <p class="text-sm text-on-surface-variant flex items-center gap-2">
              <Clock class="w-4 h-4 text-secondary shrink-0" /> We typically respond
              within one business day.
            </p>

            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-primary hover:bg-primary-container px-8 py-3.5 text-sm font-semibold text-on-primary transition duration-300 shadow-subtle active:scale-[0.98] cursor-pointer"
            >
              Send Message <Send class="w-4 h-4" />
            </button>
          </div>
        </form>
      </div>

      <!-- Sidebar Contact Details -->
      <aside class="flex flex-col gap-6">
        <!-- Quick Note card -->
        <div
          class="rounded-3xl border border-outline-variant/30 bg-surface-container p-6 sm:p-8 shadow-subtle flex flex-col justify-between"
        >
          <div
            class="rounded-2xl bg-surface-container-lowest p-6 shadow-xs border border-outline-variant/25"
          >
            <span
              class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary"
              >ScholrBee Helpdesk</span
            >
            <h3 class="mt-3 font-display text-headline-md text-primary">
              Support, Product Demos & Partnership Inquiries
            </h3>
            <p
              class="mt-3 text-body-sm sm:text-body-md text-on-surface-variant leading-relaxed"
            >
              Our support specialists and instructional designers are ready to
              help you with academic onboarding, campus integrations, and custom
              features.
            </p>
          </div>

          <div class="mt-6 space-y-4">
            {
              contactLinks.map((item) => (
                <div class="flex items-start justify-between gap-4 rounded-2xl border border-outline-variant/20 bg-surface-container-lowest px-5 py-4 shadow-xs">
                  <span class="text-xs sm:text-sm font-medium text-outline-variant text-on-surface-variant">
                    {item.label}
                  </span>
                  <span class="text-right text-xs sm:text-sm font-semibold text-primary">
                    {item.value}
                  </span>
                </div>
              ))
            }
          </div>

          <div
            class="mt-6 rounded-2xl border border-secondary/20 bg-secondary/5 p-5"
          >
            <span
              class="text-xs font-semibold uppercase tracking-[0.12em] text-secondary flex items-center gap-2"
            >
              <MessageSquare class="w-4 h-4" /> Pro tip
            </span>
            <p
              class="mt-2 text-xs sm:text-sm leading-relaxed text-secondary/90 font-medium"
            >
              If you are reporting a bug or requiring immediate technical help,
              please include your registered account email and device type for
              speedier diagnostics.
            </p>
          </div>
        </div>
      </aside>
    </section>
  </div>
</Layout>
