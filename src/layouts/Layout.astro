---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title = "ScholrBee - Best AI Study App for Students",
  description = "ScholrBee is the best studying app for students. An AI-native study app with flashcards, mind maps, active recall, and spaced repetition to help you stay focused and ace your exams.",
  keywords = "studying app, study app, student study app, best studying app, AI study app, gamify studying app, study planner app",
  ogImage = "/scholrbee_logo.png",
} = Astro.props;
const canonicalURL = Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="ScholrBee" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta
      property="og:image"
      content={new URL(ogImage, canonicalURL).toString()}
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="ScholrBee" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL(ogImage, canonicalURL).toString()}
    />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <!-- Font preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ScholrBee" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Additional SEO tags -->
    <meta name="theme-color" content="#6366f1" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <!-- Schema.org structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "ScholrBee",
        description: description,
        applicationCategory: "EducationalApplication",
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD",
        },
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: "4.8",
          ratingCount: "1250",
        },
        url: canonicalURL.toString(),
        image: new URL("/scholrbee_logo.png", canonicalURL).toString(),
      })}
    />
  </head>
  <body class="bg-surface mt-5">
    <main>
      <slot />
    </main>

    <footer class="bg-surface text-on-surface">
      <div class="mx-auto w-full">
        <div class="border-t border-outline-variant/40 py-10 sm:py-12">
          <div class="mx-auto flex max-w-xl flex-col items-center text-center">
            <a
              href="/"
              class="font-display text-headline-md text-primary transition-colors duration-300 hover:text-secondary"
            >
              ScholrBee
            </a>

            <p
              class="mt-4 text-body-sm text-on-surface-variant sm:text-body-md"
            >
              @ <span id="year"></span> ScholrBee. Built for high-achievers.
            </p>

            <nav
              aria-label="Footer"
              class="mt-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-2"
            >
              <a
                href="/"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Home
              </a>
              <a
                href="/#features"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Features
              </a>
              <a
                href="/#pricing"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Pricing
              </a>
              <a
                href="/about"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                About Us
              </a>
              <a
                href="/contact"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Contact Us
              </a>
              <a
                href="/privacy"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Privacy Policy
              </a>
              <a
                href="/terms"
                class="font-sans text-label-md text-on-surface-variant transition-colors duration-300 hover:text-primary"
              >
                Terms & Conditions
              </a>
            </nav>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const yearElement = document.getElementById("year");
      if (yearElement) {
        yearElement.textContent = new Date().getFullYear().toString();
      }
    </script>
  </body>
</html>
